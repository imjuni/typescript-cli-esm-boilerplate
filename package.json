{
	"name": "typescript-cli-esm-boilerplate",
	"version": "1.0.0",
	"description": "TypeScript cli esm boilerplate",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "tsx src/cli.ts",
		"debug": "tsx --inspect-brk src/cli.ts",
		"preartifact": "pnpm run clean",
		"artifact": "cross-env FORMAT=esm node .configs/esbuild.mjs",
		"test": "vitest run --coverage",
		"clean": "rimraf dist artifact",
		"lint": "biome check .",
		"lint-staged": "biome check --write --staged --files-ignore-unknown=true --no-errors-on-unmatched",
		"build": "tsc --incremental --noEmit --project tsconfig.prod.json",
		"rollup:prod": "rollup --config ./.configs/rollup.config.prod.ts --configPlugin typescript",
		"rollup:dev": "rollup --config ./.configs/rollup.config.dev.ts --configPlugin typescript",
		"dd": "deps-diff md -d prod -d dev --title-list-type '*' --deps-list-type '*' --content-list-type '*'",
		"prepare": "husky install"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/imjuni/typescript-cli-boilerplate.git"
	},
	"keywords": [],
	"author": "ByungJoon Lee",
	"license": "MIT",
	"main": "dist/cli.js",
	"types": "dist/cli.d.ts",
	"bin": {
		"cli-esm": "dist/cli.js"
	},
	"imports": {
		"#modules/*": "./src/modules/*",
		"#commands/*": "./src/commands/*",
		"#i18n/*": "./src/i18n/*",
		"#schema/*": "./src/schema/*"
	},
	"bugs": {
		"url": "https://github.com/imjuni/typescript-cli-boilerplate/issues"
	},
	"homepage": "https://github.com/imjuni/typescript-cli-boilerplate#readme",
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@rollup/plugin-node-resolve": "^15.2.3",
		"@tsconfig/node22": "^22.0.5",
		"@types/cli-progress": "^3.11.6",
		"@types/node": "^20.14.11",
		"@types/source-map-support": "^0.5.10",
		"@types/yargs": "^17.0.31",
		"@vitest/coverage-v8": "^4.1.7",
		"cross-env": "^10.1.0",
		"deps-diff": "^1.0.2",
		"esbuild": "^0.28.0",
		"execa": "^9.3.0",
		"husky": "^9.0.11",
		"read-pkg": "^10.1.0",
		"rimraf": "^6.0.1",
		"rollup": "^4.18.1",
		"rollup-plugin-dts": "^6.1.1",
		"ts-node": "^10.9.1",
		"tsconfig-paths": "^4.2.0",
		"tslib": "^2.6.3",
		"tsx": "^4.16.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"c12": "4.0.0-beta.5",
		"chalk": "^5.3.0",
		"citty": "^0.2.2",
		"cli-progress": "^3.12.0",
		"consola": "^3.2.3",
		"defu": "^6.1.7",
		"my-easy-fp": "^0.23.0",
		"rosetta": "^1.1.0",
		"source-map-support": "^0.5.21",
		"url-naong": "^1.3.0",
		"zod": "^4.4.3"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"cross-env NODE_ENV=production eslint --cache"
		],
		"*.{js,jsx,ts,tsx},*.json,.{eslintrc.cjs,prettierrc}": [
			"cross-env NODE_ENV=production prettier --ignore-path .eslintignore --parser json --write"
		]
	}
}
